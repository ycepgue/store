# URL of the backend API used by the browser and, by default, by SSR too.
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Optional: internal URL for server-side (SSR) requests only. Set this ONLY
# when the Nuxt server should reach the backend at a different address than
# the browser (e.g. http://backend:3001/api in a private network).
# If unset, SSR falls back to NUXT_PUBLIC_API_BASE_URL.
# NUXT_API_BASE_URL=
